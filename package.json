{
  "name": "aathena",
  "version": "0.1.0",
  "description": "Type-safe AWS Athena client with codegen",
  "author": "bug3",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "aathena": "./dist/cli/index.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./runtime": {
      "import": "./dist/runtime/index.mjs",
      "require": "./dist/runtime/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/"
  },
  "keywords": [
    "athena",
    "aws-athena",
    "aws",
    "typescript",
    "type-safe",
    "codegen",
    "sql"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-athena": "^3.750.0",
    "@aws-sdk/client-glue": "^3.750.0",
    "sql-render": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
